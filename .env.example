# ── NVIDIA NIM ────────────────────────────────────────────────────────
NIM_API_KEY=
NIM_API_URL=https://integrate.api.nvidia.com

# ── Database ───────────────────────────────────────────────────────────
# Local dev: a plain Postgres URL.
# Production (Supabase free tier) — use the RIGHT endpoint per consumer:
#   • Vercel app  → POOLED / transaction pooler (port 6543, host has "pooler"):
#       postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   • Worker + `prisma migrate deploy` → DIRECT connection (port 5432):
#       postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
# The pooler can't run migrations or hold transactions reliably; the direct URL
# can't handle serverless connection fan-out. Use each where noted.
DATABASE_URL="postgresql://user:pass@host:5432/nim_stats?schema=public"

# ── Internal API token ────────────────────────────────────────────────
# Locks down the non-browser API routes (anomalies, quota, overview, models,
# providers). Unset = open (fine for local dev). MUST be set in production —
# send it as `Authorization: Bearer <token>` to reach those routes.
# Generate: `openssl rand -hex 32`
INTERNAL_API_TOKEN=

# ── Cron trigger (prod only — for /api/cron/trigger) ──────────────────
# An external scheduler (e.g. cron-job.org) POSTs to /api/cron/trigger with
# CRON_SECRET to fire the probe promptly; the route then dispatches the GitHub
# Actions workflow using GH_DISPATCH_TOKEN (a fine-grained PAT scoped to
# `Actions: read/write` on this repo only). Only needed if you use the external
# scheduler instead of GitHub's built-in (delayed) cron.
# CRON_SECRET=               # openssl rand -hex 32 — held by the scheduler
# GH_DISPATCH_TOKEN=         # GitHub fine-grained PAT (Actions: write, this repo)

# ── Upstash Redis (NOT required) ──────────────────────────────────────
# Currently unused — the probe rate limiter is in-process. Left here only as a
# future hook; safe to omit entirely in production.
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ── Tuning knobs ──────────────────────────────────────────────────────
PROBE_MAX_RPM=30               # outbound probe cap (NVIDIA NIM free tier = 40 rpm; keep margin)
PROBE_CONCURRENCY=6            # max in-flight probes (start rate still capped by PROBE_MAX_RPM)
SYNC_INTERVAL_MS=21600000      # 6 h between model-registry syncs
RETENTION_DAYS=30              # prune samples older than this

# ── Worker schedules (node-cron — LOCAL dev only) ─────────────────────
# These drive the always-on `npm run worker`. In production the worker doesn't
# run; GitHub Actions invokes `scripts/probe-once.ts` instead (probe every 5 min,
# maintenance daily) — see .github/workflows/. 5 min keeps ModelSample well
# inside Neon's free 0.5 GB (~86 MB at ~50 models × 30-day retention; 1-min would
# overflow it).
PROBE_WORKER_CRON=* * * * *        # probe every active endpoint each minute
MODEL_REGISTRY_SYNC_CRON=0 */6 * * *  # re-sync the NIM model registry every 6 h
MAINTENANCE_CRON=0 3 * * *         # prune old samples + retire dead models daily

# Operational thresholds (override defaults without code change)
TTFT_HEALTHY_MAX=150
TTFT_BUSY_MAX=500
ERROR_RATE_JAMMED=0.3
ERROR_RATE_BUSY=0.1
TIMEOUT_RATE_JAMMED=0.2
CONGESTION_JAMMED=0.7
CONGESTION_BUSY=0.3
MIN_SAMPLES_FOR_CLASSIFICATION=3
