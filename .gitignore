# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Secrets & environment ─────────────────────────────────────────────
# Real env files hold live credentials (NIM_API_KEY, DATABASE_URL) — never commit.
.env
.env.*
.env.local
.env.*.local
*.env.enc
.envrc
# ...but keep the safe, key-less templates under version control.
!.env.sample
!.env.template

# Keys, certificates & credential bundles
*.pem
*.key
*.crt
*.cert
*.cer
*.der
*.p12
*.pfx
*.keystore
*.jks
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Credential files & secret stores
secrets/
.secrets/
secrets.json
credentials.json
service-account*.json
gha-creds-*.json
*.secret

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
